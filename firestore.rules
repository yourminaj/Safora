rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Emergency contacts subcollection — owner-only access.
      match /emergency_contacts/{contactId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // FCM tokens subcollection — owner-only access.
      match /fcm_tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // SOS events — owner can write; authenticated contacts can read
      // (contact's phone number must be listed in contactPhones array).
      match /sos_events/{eventId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null
          && resource.data.contactPhones.hasAny([request.auth.token.phone_number]);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
