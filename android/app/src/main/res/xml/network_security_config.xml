<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP for Bangladesh Flood Forecasting (no HTTPS support) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">www.ffwc.gov.bd</domain>
    </domain-config>
</network-security-config>
